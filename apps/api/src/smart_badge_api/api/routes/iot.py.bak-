    iot_audio_to_dvi_audio,
    iot_batch_assign_employees,
    iot_control_gps,
    iot_query_audio_task,
    iot_submit_audio_task,
    iot_update_device_settings,
    iot_voice_print_create,
    iot_voice_print_delete,
    iot_voice_print_list,
    iot_voice_print_update,
)
