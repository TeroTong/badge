def _norm(value: object) -> str:
    return re.sub(r"[^a-z0-9]+", "", str(value or "").lower())


def _iter_dicts(value: object, *, depth: int = 0):
    if depth > 6:
        return
    if isinstance(value, dict):
        yield value
        for child in value.values():
            yield from _iter_dicts(child, depth=depth + 1)
    elif isinstance(value, list):
        for child in value[:20]:
            yield from _iter_dicts(child, depth=depth + 1)


def _lookup(payload: dict[str, Any], *keys: str) -> object | None:
    targets = {_norm(key) for key in keys}
    for item in _iter_dicts(payload):
        for key, value in item.items():
            if _norm(key) in targets:
                return value
    return None


def _callback_capability_key(event_name: str | None, payload: dict[str, Any]) -> tuple[str, str]:
    raw_event = event_name or _clean_text(
        _lookup(payload, "eventType", "event", "type", "msgType", "callbackType")
    )
    event = str(raw_event or "developer").strip().lower().replace("_", "-")
    normalized = _norm(event)

    if "voice" in normalized or "voiceprint" in normalized:
        return event, "callback_voice_print"
    if "exception" in normalized or "alarm" in normalized or "error" in normalized:
        return event, "callback_device_exception"
    if "developer" in normalized or "config" in normalized:
        return event, "callback_developer"
    if "gps" in normalized and "status" in normalized:
        return event, "callback_gps_status"
    if "gps" in normalized or "location" in normalized:
        return event, "callback_gps"
    if "audio" in normalized or "record" in normalized or "file" in normalized:
        return event, "callback_audio"
    if "device" in normalized or "status" in normalized or "battery" in normalized:
        return event, "callback_device_status"
    return event, "callback_developer"


def _normalize_status(online_value: object, record_status: object) -> str | None:
    record_value = _coerce_int(record_status)
    if record_value == 1:
        return "recording"

    if isinstance(online_value, bool):
        return "online" if online_value else "offline"
    online_int = _coerce_int(online_value)
    if online_int == 1:
        return "online"
    if online_int == 0:
        return "offline"

    text = str(online_value or "").strip().lower()
    if text in {"online", "idle", "recording"}:
        return text
    if text in {"offline", "off"}:
        return "offline"
    return None


async def _process_device_status_callback(db: AsyncSession, payload: dict[str, Any]) -> dict[str, Any]:
    device_no = _clean_text(
        _lookup(payload, "deviceNo", "sn", "deviceCode", "device_no", "deviceId")
    )
    if not device_no:
        return {"updated": False, "reason": "missing deviceNo"}

    battery = _coerce_int(_lookup(payload, "remainPower", "battery", "batteryLevel", "power"))
    status_value = _normalize_status(
        _lookup(payload, "onlineStatus", "online", "status", "deviceStatus"),
        _lookup(payload, "recordStatus", "recordingStatus"),
    )

    device = (
        await db.execute(select(Device).where(Device.device_code == device_no).limit(1))
    ).scalar_one_or_none()
    if device is None:
        device = Device(
            name=device_no,
            device_code=device_no,
            status=status_value or "offline",
            battery_level=battery,
        )
        db.add(device)
    else:
        if status_value:
            device.status = status_value
        if battery is not None:
            device.battery_level = battery
    await db.commit()
    await db.refresh(device)
    if battery is not None:
        await handle_device_battery_update(db, device, battery_level=battery)
    return {
        "updated": True,
        "deviceNo": device_no,
        "status": status_value,
        "battery": battery,
    }


def _candidate_dicts(payload: dict[str, Any]):
    yield payload
    for key in ("data", "payload", "audio", "record", "file", "body"):
        value = payload.get(key)
        if isinstance(value, dict):
            yield value
        elif isinstance(value, list):
            for item in value[:20]:
                if isinstance(item, dict):
                    yield item


def _adapt_audio_payload(raw: dict[str, Any]) -> dict[str, Any]:
    adapted = dict(raw)
    if "deviceNo" not in adapted:
        for key in ("sn", "deviceCode", "device_no", "deviceId"):
            if key in adapted:
                adapted["deviceNo"] = adapted[key]
                break
    if "eventId" not in adapted and "fileId" in adapted:
        file_id = str(adapted["fileId"] or "")
        adapted["eventId"] = file_id.removeprefix("iot:")
    if "fileUrl" not in adapted and "downloadUrl" in adapted:
        adapted["fileUrl"] = adapted["downloadUrl"]
    if "seconds" not in adapted and "duration" in adapted:
        duration = _coerce_int(adapted.get("duration"))
        if duration is not None:
            adapted["seconds"] = int(duration / 1000) if duration > 1000 else duration
    return adapted


def _audio_item_from_callback(payload: dict[str, Any]) -> RemoteAudioItem | None:
    for candidate in _candidate_dicts(payload):
        normalized = iot_audio_to_dvi_audio(_adapt_audio_payload(candidate))
        if normalized is None:
            continue
        return RemoteAudioItem(
            sn=str(normalized["sn"]),
            file_id=str(normalized["fileId"]),
            file_name=_clean_text(normalized.get("fileName")),
            duration_ms=_coerce_int(normalized.get("duration")),
            file_size=_coerce_int(normalized.get("fileSize")),
            create_time_ms=_coerce_int(normalized.get("createTime")),
            download_url=_clean_text(normalized.get("downloadUrl")),
            source="iot",
        )
    return None


async def _archive_iot_audio_item(item: RemoteAudioItem) -> None:
    try:
        await archive_audio_item(item)
    except Exception:
        logger.exception("failed to archive IOT callback audio %s/%s", item.sn, item.file_id)


async def _read_callback_payload(request: Request) -> dict[str, Any]:
    try:
        payload = await request.json()
    except Exception:
        raw = await request.body()
        return {"raw": raw.decode("utf-8", errors="replace")}
    return payload if isinstance(payload, dict) else {"payload": payload}


async def _receive_iot_callback(
    *,
    event_name: str | None,
    request: Request,
    background_tasks: BackgroundTasks,
    db: AsyncSession,
) -> dict[str, Any]:
    payload = await _read_callback_payload(request)
    resolved_event, capability_key = _callback_capability_key(event_name, payload)
    capabilities = await get_iot_capabilities(db)
    if not capabilities.get(capability_key):
        return {
            "success": True,
            "enabled": False,
            "event": resolved_event,
            "capability": capability_key,
            "message": "IOT 回调能力未开启，已忽略",
        }

    process_result: dict[str, Any] = {"received": True}
    if capability_key == "callback_device_status":
        process_result = await _process_device_status_callback(db, payload)
    elif capability_key == "callback_audio":
        audio_item = _audio_item_from_callback(payload)
        if audio_item is not None:
            background_tasks.add_task(_archive_iot_audio_item, audio_item)
            process_result = {
                "queued": True,
                "deviceNo": audio_item.sn,
                "fileId": audio_item.file_id,
            }
        else:
            process_result = {"queued": False, "reason": "missing audio file fields"}

    await append_audit_log(
        db,
        operator_name="IOT平台回调",
        ip_address=request.client.host if request.client else "",
        module_name="IOT回调",
        action_name=capability_key,
        content=f"event={resolved_event}; result={process_result}; payload={_json_preview(payload)}",
    )
    return {
        "success": True,
        "enabled": True,
        "event": resolved_event,
        "capability": capability_key,
        "result": process_result,
    }


@callback_router.post("")
async def receive_iot_callback(
    request: Request,
    background_tasks: BackgroundTasks,
    db: AsyncSession = Depends(get_db),
):
    return await _receive_iot_callback(
        event_name=None,
        request=request,
        background_tasks=background_tasks,
        db=db,
    )


@callback_router.post("/{event_name}")
async def receive_named_iot_callback(
    event_name: str,
    request: Request,
    background_tasks: BackgroundTasks,
    db: AsyncSession = Depends(get_db),
):
    return await _receive_iot_callback(
        event_name=event_name,
        request=request,
        background_tasks=background_tasks,
        db=db,
    )
