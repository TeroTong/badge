    get_iot_capabilities,
    iot_capability_definitions_payload,
    require_iot_capability,
    update_iot_capabilities,
)

logger = logging.getLogger("smart_badge.iot_routes")

router = APIRouter(prefix="/iot", tags=["IOT能力"])
callback_router = APIRouter(prefix="/iot/callbacks", tags=["IOT回调"])


class IotCapabilityUpdate(BaseModel):
    capabilities: dict[str, bool] = Field(default_factory=dict)


class IotGpsControlRequest(BaseModel):
    device_no: str = Field(..., alias="deviceNo")
    order_no: str | None = Field(None, alias="orderNo")

    model_config = {"populate_by_name": True}


class IotDeviceSettingsRequest(BaseModel):
    device_nos: list[str] = Field(..., alias="deviceNos")
    allow_clip: int = Field(..., alias="allowClip", ge=0, le=1)
    clip_seconds: int = Field(..., alias="clipSeconds", ge=1)
    fail_seconds: int | None = Field(None, alias="failSeconds", ge=0)
    allow_play: int | None = Field(None, alias="allowPlay", ge=0, le=1)
    audio_volume: int | None = Field(None, alias="audioVolume", ge=0, le=100)
    gps_enable: int | None = Field(None, alias="gpsEnable", ge=0, le=1)
    auto_upload: int | None = Field(None, alias="autoUpload", ge=0, le=1)
    environment_id: int | None = Field(None, alias="environmentId")

    model_config = {"populate_by_name": True}


class IotEmployeeBindingRequest(BaseModel):
    binds: list[dict[str, Any]]
    operator_id: int | None = Field(None, alias="operatorId")

    model_config = {"populate_by_name": True}


class IotAudioTaskSubmitRequest(BaseModel):
    device_no: str = Field(..., alias="deviceNo")
    start_time: str = Field(..., alias="startTime")
    end_time: str = Field(..., alias="endTime")
    callback_url: str | None = Field(None, alias="callbackUrl")
    ori_task_id: str | None = Field(None, alias="oriTaskId")
    order_no: str | None = Field(None, alias="orderNo")

    model_config = {"populate_by_name": True}


class IotVoicePrintCreateRequest(BaseModel):
    device_no: str = Field(..., alias="deviceNo")
    callback_url: str = Field(..., alias="callbackUrl")

    model_config = {"populate_by_name": True}


class IotVoicePrintUpdateRequest(IotVoicePrintCreateRequest):
    voice_print_id: str = Field(..., alias="voicePrintId")


class IotVoicePrintListRequest(BaseModel):
    page: int = Field(1, ge=1)
    size: int = Field(100, ge=1, le=100)
    device_no: str | None = Field(None, alias="deviceNo")
    voice_print_id: str | None = Field(None, alias="voicePrintId")
    start_time: str | None = Field(None, alias="startTime")
    stop_time: str | None = Field(None, alias="stopTime")

    model_config = {"populate_by_name": True}


class IotVoicePrintDeleteRequest(BaseModel):
    voice_print_id: str = Field(..., alias="voicePrintId")

    model_config = {"populate_by_name": True}


def _handle_iot_error(exc: DingTalkConfigError | DingTalkApiError) -> HTTPException:
    if isinstance(exc, DingTalkConfigError):
        return HTTPException(status_code=501, detail=str(exc))
    return HTTPException(status_code=502, detail=str(exc))


def _clean_text(value: object) -> str | None:
    text = str(value or "").strip()
    return text or None


def _coerce_int(value: object) -> int | None:
    if value is None or isinstance(value, bool):
        return None
    if isinstance(value, int):
        return value
    if isinstance(value, float):
        return int(value)
    try:
        return int(float(str(value).strip()))
    except (TypeError, ValueError):
        return None


def _json_preview(payload: object, *, limit: int = 1500) -> str:
    try:
        text = json.dumps(payload, ensure_ascii=False, default=str)
    except TypeError:
        text = str(payload)
    return text if len(text) <= limit else f"{text[:limit]}..."


async def _append_admin_audit(
    db: AsyncSession,
    *,
    request: Request,
    current_user: User,
    action_name: str,
    content: str,
) -> None:
    await append_audit_log(
        db,
        operator_name=current_user.display_name or current_user.username,
        ip_address=request.client.host if request.client else "",
        module_name="IOT能力",
        action_name=action_name,
        content=content,
    )


@router.get("/capabilities")
async def list_iot_capabilities(db: AsyncSession = Depends(get_db)):
    return {
        "definitions": iot_capability_definitions_payload(),
        "capabilities": await get_iot_capabilities(db),
    }


@router.put("/capabilities")
async def save_iot_capabilities(
    body: IotCapabilityUpdate,
    request: Request,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user),
):
    capabilities = await update_iot_capabilities(db, body.capabilities)
    enabled = [
        item["title"]
        for item in iot_capability_definitions_payload()
        if capabilities.get(item["key"])
    ]
    await _append_admin_audit(
        db,
        request=request,
        current_user=current_user,
        action_name="更新IOT能力开关",
        content=f"当前开启：{', '.join(enabled) if enabled else '无'}",
    )
    return {
        "definitions": iot_capability_definitions_payload(),
        "capabilities": capabilities,
    }


@router.post("/devices/gps/{action}")
async def control_iot_gps(
    action: Literal["start", "stop", "curr_location"],
    body: IotGpsControlRequest,
    request: Request,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user),
):
    await require_iot_capability(db, "gps_control")
    try:
        result = await iot_control_gps(
            action=action,
            device_no=body.device_no,
            order_no=body.order_no,
        )
    except (DingTalkConfigError, DingTalkApiError) as exc:
        raise _handle_iot_error(exc) from exc
    await _append_admin_audit(
        db,
        request=request,
        current_user=current_user,
        action_name="IOT GPS控制",
        content=f"{body.device_no} 执行 {action}",
    )
    return result


@router.post("/devices/settings")
async def update_iot_device_settings_route(
    body: IotDeviceSettingsRequest,
    request: Request,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user),
):
    await require_iot_capability(db, "device_settings")
    try:
        result = await iot_update_device_settings(
            device_nos=body.device_nos,
            allow_clip=body.allow_clip,
            clip_seconds=body.clip_seconds,
            fail_seconds=body.fail_seconds,
            allow_play=body.allow_play,
            audio_volume=body.audio_volume,
            gps_enable=body.gps_enable,
            auto_upload=body.auto_upload,
            environment_id=body.environment_id,
        )
    except (DingTalkConfigError, DingTalkApiError) as exc:
        raise _handle_iot_error(exc) from exc
    await _append_admin_audit(
        db,
        request=request,
        current_user=current_user,
        action_name="IOT设备参数设置",
        content=f"更新 {len(body.device_nos)} 台设备参数",
    )
    return result


@router.post("/devices/employee-bindings")
async def batch_assign_iot_employees(
    body: IotEmployeeBindingRequest,
    request: Request,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user),
):
    await require_iot_capability(db, "employee_binding")
    if not body.binds:
        raise HTTPException(status_code=400, detail="绑定列表不能为空")
    try:
        result = await iot_batch_assign_employees(
            binds=body.binds,
            operator_id=body.operator_id,
        )
    except (DingTalkConfigError, DingTalkApiError) as exc:
        raise _handle_iot_error(exc) from exc
    await _append_admin_audit(
        db,
        request=request,
        current_user=current_user,
        action_name="IOT员工绑定同步",
        content=f"同步 {min(len(body.binds), 500)} 条员工绑定",
    )
    return result


